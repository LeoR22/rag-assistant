# GitHub Models (Azure OpenAI)
GITHUB_TOKEN=gsk_tu-groq-api-key
LLM_MODEL=openai/gpt-oss-20b
LLM_BASE_URL=https://api.groq.com/openai/v1

# Embeddings
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# ChromaDB
CHROMA_PATH=data/chroma
CHROMA_COLLECTION=bancolombia

# Datos del scraper
RAW_DATA_PATH=../scraper/data/raw

# Memoria
SHORT_TERM_MAX_MESSAGES=20
LONG_TERM_DB_PATH=data/memory.db

# Agent API
AGENT_HOST=0.0.0.0
AGENT_PORT=8001

# Servidor MCP
MCP_SERVER_URL=http://localhost:8000/mcp
MCP_SERVER_NAME=bancolombia-knowledge-base
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8000

# Opciones: stdio | streamable-http
MCP_TRANSPORT=streamable-http

LANGFUSE_PUBLIC_KEY=tu_key
LANGFUSE_SECRET_KEY=tu_secret
LANGFUSE_HOST=https://us.cloud.langfuse.com


ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://frontend-production-1bed.up.railway.app

# General
LOG_LEVEL=INFO